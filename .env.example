# Admin password for the /admin CMS panel
ADMIN_PASSWORD=change-me-to-a-strong-password

# Secret used to encrypt the session cookie (must be at least 32 characters)
SESSION_SECRET=change-me-to-a-random-32-char-string!!

# Formspree form ID for quote email notifications (from https://formspree.io)
FORMSPREE_FORM_ID=your-formspree-form-id

# Gmail SMTP for customer confirmation emails
GMAIL_USER=info@hydrapoolservices.com
GMAIL_APP_PASSWORD=your-google-app-password

# ── Stripe (Subscription Checkout) ────────────────────────
# Secret API key from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_test_your-key-here

# Webhook signing secret (from Stripe Dashboard > Webhooks)
STRIPE_WEBHOOK_SECRET=whsec_your-secret-here

# Recurring Price IDs — create Products + Prices in Stripe Dashboard, copy Price IDs here
STRIPE_PRICE_BIWEEKLY=price_your-biweekly-price-id
STRIPE_PRICE_WEEKLY=price_your-weekly-price-id
STRIPE_PRICE_PREMIUM_CARE=price_your-premium-care-price-id

# Base URL for redirect URLs (e.g. https://www.hydrapoolservices.com)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
